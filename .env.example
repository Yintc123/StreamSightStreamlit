# 環境變數範本；複製為 .env 並填入實際值後使用
# 欄位說明見 lib/config.py 與 docs/specs/config.md

# ── 執行環境 ──────────────────────────────────────────────
# 合法值: local | development | stage | production | test
APP_ENV=local

# ── App meta ──────────────────────────────────────────────
APP_NAME=StreamSight
APP_VERSION=0.0.0
APP_COMMIT=
# LOG_LEVEL 由 APP_ENV 子類決定（local/dev=DEBUG, stage/prod=INFO），通常不需覆寫
# LOG_LEVEL=DEBUG

# ── 功能開關 ──────────────────────────────────────────────
# ENABLE_THEME_TOGGLE: 主題切換 icon 顯示開關；0=隱藏（預設）/ 1=顯示
ENABLE_THEME_TOGGLE=0

# ── 資料來源 & 認證模式 ────────────────────────────────────
# USE_MOCK: true/1=mock data + mock auth; false/0=FastAPI + BFF（對齊前端 USE_MOCK）
# local/test 預設 true；development/stage/production 預設 false
# production 強制禁 mock（見 §5.4）
USE_MOCK=true

# ── BFF（Next.js）base URL ────────────────────────────────
# stage/production 必須為 HTTPS 且非 localhost（見 §5.3）
# BFF_BASE_URL：server-side 呼叫用（introspection / logout）
BFF_BASE_URL=http://localhost:3000
# BFF_PUBLIC_BASE_URL：瀏覽器可達位址（登入重導 / TopBar 連結）；
# 未設則回退 BFF_BASE_URL。docker 部署時兩者不同（內部主機名 vs localhost）。
BFF_PUBLIC_BASE_URL=
FASTAPI_BASE_URL=http://localhost:8000

# ── Session & 路徑 ─────────────────────────────────────────
SESSION_COOKIE_NAME=streamsight_session
BFF_SESSION_PATH=/api/auth/session
BFF_LOGOUT_PATH=/api/auth/logout
BFF_LOGIN_PATH=/
BFF_CMS_PATH=/cms
STREAMLIT_ORIGIN=http://localhost:8501
# role 數值對應 admin（其餘為 user）
ROLE_ADMIN_VALUE=1

# ── HTTP client（單位：秒）────────────────────────────────
HTTP_CONNECT_TIMEOUT_SECONDS=3
HTTP_READ_TIMEOUT_SECONDS=10
# 網路重試上限（僅 GET）
HTTP_RETRY_MAX=2
HTTP_RETRY_BASE_SECONDS=0.2
HTTP_RETRY_FACTOR=2

# ── Request ID ────────────────────────────────────────────
REQUEST_ID_HEADER=X-Request-ID
REQUEST_ID_PREFIX=st

# ── Token / introspection cache ───────────────────────────
TOKEN_REFRESH_THRESHOLD_SECONDS=60
INTROSPECTION_CACHE_TTL_SECONDS=30
