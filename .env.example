# 環境變數範本；複製為 .env 並填入實際值後使用
# 欄位說明見 lib/config.py 與 docs/specs/config.md

# ── 執行環境 ──────────────────────────────────────────────
# 合法值: local | development | stage | production | test
APP_ENV=local

# ── App meta ──────────────────────────────────────────────
APP_NAME=StreamSight
APP_VERSION=0.0.0
APP_COMMIT=
# 各環境預設: local/development=DEBUG, stage/production=INFO
LOG_LEVEL=DEBUG

# ── 資料來源 & 認證模式 ────────────────────────────────────
# DATA_SOURCE: mock | api
# AUTH_MODE  : mock | bff
# 限制: DATA_SOURCE=api 必須搭配 AUTH_MODE=bff（見 §5.2）
#       production 禁用 mock（見 §5.4）
DATA_SOURCE=mock
AUTH_MODE=mock

# ── BFF（Next.js）base URL ────────────────────────────────
# stage/production 必須為 HTTPS 且非 localhost（見 §5.3）
BFF_BASE_URL=http://localhost:3000
FASTAPI_BASE_URL=http://localhost:3001

# ── Session & 路徑 ─────────────────────────────────────────
SESSION_COOKIE_NAME=streamsight_session
BFF_SESSION_PATH=/api/auth/session
BFF_LOGOUT_PATH=/api/auth/logout
BFF_LOGIN_PATH=/login
BFF_CMS_PATH=/cms
STREAMLIT_ORIGIN=http://localhost:8501
# role 數值對應 admin（其餘為 user）
ROLE_ADMIN_VALUE=1

# ── HTTP client（單位：秒）────────────────────────────────
HTTP_CONNECT_TIMEOUT_SECONDS=3
HTTP_READ_TIMEOUT_SECONDS=10
# 網路重試上限（僅 GET）
HTTP_RETRY_MAX=2
HTTP_RETRY_BASE_SECONDS=0.2
HTTP_RETRY_FACTOR=2

# ── Request ID ────────────────────────────────────────────
REQUEST_ID_HEADER=X-Request-ID
REQUEST_ID_PREFIX=st

# ── Token / introspection cache ───────────────────────────
TOKEN_REFRESH_THRESHOLD_SECONDS=60
INTROSPECTION_CACHE_TTL_SECONDS=30
